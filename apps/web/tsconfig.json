{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,

    "types": ["vite/client", "node"],

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@unio/api": ["../../packages/api/src"],
      "@unio/chrome": ["../../packages/chrome/src"],
      "@unio/ui": ["../../packages/ui/src"],
      "@unio/lib": ["../../packages/lib/src"]
    }
  },

  "include": ["src", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}